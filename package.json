{
  "name": "ygo-story-duel-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "assets:mvp": "node scripts/download-mvp-assets.ts",
    "assets:engine": "node scripts/sync-engine.ts",
    "assets:engine:verify": "node scripts/verify-engine.ts",
    "assets:sync": "node scripts/sync-assets.ts",
    "assets:sync:offline": "node scripts/sync-assets.ts --offline",
    "assets:verify": "node scripts/verify-assets.ts",
    "assets:images": "node scripts/download-images.ts",
    "assets:images:verify": "node scripts/verify-images.ts",
    "vendor:verify": "node scripts/verify-vendor.ts",
    "snapshot:generate": "node scripts/generate-runtime-snapshot.ts",
    "snapshot:verify": "node scripts/verify-runtime-snapshot.ts",
    "dev": "vite",
    "build": "npm run vendor:verify && npm run snapshot:verify && npm run build:app && npm run build:verify",
    "build:app": "vite build --mode private",
    "build:verify": "node scripts/verify-browser-build.ts",
    "build:reproducible": "node scripts/verify-reproducible-build.ts",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"tests/{unit,integration,component,fixtures}/**/*.{ts,svelte}\" \"scripts/{verify-vendor,verify-browser-build,verify-reproducible-build,generate-runtime-snapshot,verify-runtime-snapshot}.ts\" \"scripts/lib/{active-card-text-manifest,active-image-manifest,active-runtime-files,vite-runtime-assets,vite-sync-core}.ts\" \"e2e/**/*.ts\" \"index.html\" \"*.{js,json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css}\" \"tests/{unit,integration,component,fixtures}/**/*.{ts,svelte}\" \"scripts/{verify-vendor,verify-browser-build,verify-reproducible-build,generate-runtime-snapshot,verify-runtime-snapshot}.ts\" \"scripts/lib/{active-card-text-manifest,active-image-manifest,active-runtime-files,vite-runtime-assets,vite-sync-core}.ts\" \"e2e/**/*.ts\" \"index.html\" \"*.{js,json,ts}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "test:legacy": "node --test tests/*.test.ts",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test": "npm run test:legacy && npm run test:unit && npm run test:component && npm run test:integration",
    "check:headless": "npm run format:check && npm run lint && npm run typecheck && npm run test:legacy && npm run test:unit && npm run test:integration && npm run vendor:verify && npm run assets:verify && npm run snapshot:verify",
    "check:browser": "npm run test:component && npm run build && npm run build:reproducible && npm run test:e2e",
    "check": "npm run check:headless && npm run check:browser"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.20.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "phaser": "^4.2.1",
    "svelte": "^5.56.4"
  }
}
