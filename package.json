{
  "name": "ygo-story-duel-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "assets:mvp": "node scripts/download-mvp-assets.ts",
    "assets:engine": "node scripts/sync-engine.ts",
    "assets:engine:verify": "node scripts/verify-engine.ts",
    "assets:sync": "node scripts/sync-assets.ts",
    "assets:sync:offline": "node scripts/sync-assets.ts --offline",
    "assets:verify": "node scripts/verify-assets.ts",
    "assets:images": "node scripts/download-images.ts",
    "assets:images:verify": "node scripts/verify-images.ts",
    "vendor:verify": "node scripts/verify-vendor.ts",
    "snapshot:generate": "node scripts/generate-runtime-snapshot.ts",
    "snapshot:verify": "node scripts/verify-runtime-snapshot.ts",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"tests/{unit,integration,fixtures}/**/*.ts\" \"scripts/{verify-vendor,generate-runtime-snapshot,verify-runtime-snapshot}.ts\" \"*.{js,json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css}\" \"tests/{unit,integration,fixtures}/**/*.ts\" \"scripts/{verify-vendor,generate-runtime-snapshot,verify-runtime-snapshot}.ts\" \"*.{js,json,ts}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:legacy": "node --test tests/*.test.ts",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test": "npm run test:legacy && npm run test:unit && npm run test:integration",
    "check:headless": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run vendor:verify && npm run assets:verify && npm run snapshot:verify"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
